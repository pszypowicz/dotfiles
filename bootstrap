#!/usr/bin/env bash
set -euo pipefail

# Bootstrap -- run once on a fresh machine, safe to re-run

STOW_DIR="$HOME/Developer/github.com/pszypowicz"
DOTFILES_PRIVATE_DIR="$STOW_DIR/dotfiles-private"

# 1. Homebrew
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# 2. Packages
echo "Installing packages..."
brew bundle --file "$STOW_DIR/dotfiles/dot-config/brewfile/Brewfile"
if [ -f "$DOTFILES_PRIVATE_DIR/dot-config/brewfile/Brewfile.private" ]; then
    echo "Installing private packages..."
    brew bundle --file "$DOTFILES_PRIVATE_DIR/dot-config/brewfile/Brewfile.private"
fi

# 3. Dotfiles -- both repos share the same stow directory
# (~/Developer/github.com/pszypowicz) so stow can unfold directories
# shared between packages.
#
# --no-folding forces stow to create every package subdirectory as a real
# directory in the target and symlink individual files, instead of collapsing
# whole subtrees into a single dir-symlink. This matters for any config
# directory where the tool writes live runtime state next to tracked files
# (Claude Code's ~/.config/claude is the obvious case: history.jsonl,
# projects/, sessions/, caches, etc.). With folding, those writes would
# pass through a dir-symlink and land inside the git repo; without folding,
# the target dir is real and the runtime writes stay local.
echo "Stowing dotfiles..."
stow -d "$STOW_DIR" -t ~ dotfiles --dotfiles --restow --no-folding
if [ -d "$DOTFILES_PRIVATE_DIR" ]; then
    echo "Stowing private dotfiles..."
    stow -d "$STOW_DIR" -t ~ dotfiles-private --dotfiles --restow --no-folding
fi

# 4. Defaults
echo "Writing macOS defaults..."
defaults write org.hammerspoon.Hammerspoon MJConfigFile "$HOME/.config/hammerspoon/init.lua"
echo "Done."
