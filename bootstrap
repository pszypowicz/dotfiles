#!/usr/bin/env bash
set -euo pipefail

# Bootstrap - run once on a fresh machine, safe to re-run.
# Handles the public dotfiles only. Private overlays (work, personal)
# live in sibling dotfiles-private-* repos and each ship their own
# self-contained ./bootstrap.

# Resolve this repo's parent directory so bootstrap works from any clone path.
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
PACKAGE_NAME=$(basename "$SCRIPT_DIR")
STOW_DIR=$(dirname "$SCRIPT_DIR")

# 1. Homebrew
if ! command -v brew &>/dev/null; then
    echo "Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# 2. Packages
#
# Trust the exact packages we install from non-official taps before the bundle
# runs. With HOMEBREW_REQUIRE_TAP_TRUST set (see the fish env), brew refuses to
# load a formula or cask from a non-official tap unless it is explicitly
# trusted, so an untrusted entry would abort the bundle. Trust the tap-qualified
# Brewfile entries (user/tap/name form) and nothing broader, so trust tracks
# precisely what we install rather than blanket-trusting every formula a tap
# might ever ship. brew trust only records the name - it does not need the tap
# present - so trusting before the bundle taps anything is safe.
BREWFILE="$SCRIPT_DIR/dot-config/brewfile/Brewfile"
echo "Trusting tap packages..."
while IFS= read -r line; do
    if [[ "$line" =~ ^brew\ \"([^\"/]+/[^\"/]+/[^\"/]+)\" ]]; then
        brew trust --formula "${BASH_REMATCH[1]}"
    elif [[ "$line" =~ ^cask\ \"([^\"/]+/[^\"/]+/[^\"/]+)\" ]]; then
        brew trust --cask "${BASH_REMATCH[1]}"
    fi
done <"$BREWFILE"

echo "Installing packages..."
brew bundle --file "$BREWFILE"

# 3. Dotfiles
#
# --no-folding forces stow to create every package subdirectory as a real
# directory in the target and symlink individual files, instead of collapsing
# whole subtrees into a single dir-symlink. This matters for any config
# directory where the tool writes live runtime state next to tracked files
# (Claude Code's ~/.config/claude is the obvious case: history.jsonl,
# projects/, sessions/, caches, etc.). With folding, those writes would
# pass through a dir-symlink and land inside the git repo; without folding,
# the target dir is real and the runtime writes stay local.
echo "Stowing dotfiles..."
stow -d "$STOW_DIR" -t ~ "$PACKAGE_NAME" --dotfiles --restow --no-folding

# 4. npm globals - tools with no brew formula (or newer than the brew one)
if command -v npm &>/dev/null; then
    echo "Installing npm globals..."
    npm install -g \
        @anthropic-ai/claude-code \
        @lhci/cli \
        cf \
        lighthouse \
        yarn
fi

# 5. Defaults
echo "Writing macOS defaults..."
"$SCRIPT_DIR/macos/defaults"
echo "Done."
