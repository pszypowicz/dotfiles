#!/usr/bin/env bash
set -euo pipefail

# macos/defaults - apply macOS preference defaults.
# Idempotent and safe to re-run. Invoked from ../bootstrap, but can also
# be run standalone to re-apply just this block without redoing the rest
# of the bootstrap.

usage() {
    cat <<'EOF'
Usage: macos/defaults [--help]

Apply macOS preference defaults. Idempotent and safe to re-run.

Touches:
  - Trackpad: disable the 4-finger gestures - horizontal swipe, vertical
    swipe, Launchpad pinch, Show Desktop spread. Explicitly enable 3-finger
    vertical swipe (up opens Mission Control, down App Expose); 3-finger
    horizontal keeps its macOS default (switches Spaces)
  - Menu bar: always autohide
  - Windows: Ctrl+Cmd+drag anywhere inside a window to move it
  - Dock: autohide, tile size 59
  - Finder: enable the Quit menu item (Cmd+Q)
  - Cyclist: enable the AeroSpace integration
  - Text input: disable auto-capitalization, smart quotes/dashes,
    auto-period, spelling correction, smart-reply suggestions
  - Keyboard: remap Caps Lock to Escape for all keyboards (the "All Keyboards"
    Modifier Keys entry; takes effect after logout)
  - Mission Control: keep the overview enabled on its Ctrl+Up default (takes
    effect after logout). Space-switch hotkeys stay on macOS defaults;
    Cyclist consumes Ctrl+Left/Right while it runs, and the native binding
    underneath is the fallback when it does not.

Options:
  -h, --help    Show this help and exit.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
    esac
done

# Trackpad: disable the 4-finger gestures - horizontal swipe (Space switching
# is covered by the 3-finger swipe and Cyclist's Ctrl+Arrow), vertical swipe
# (Mission Control and App Expose are covered by the 3-finger swipe), and
# the Launchpad pinch / Show Desktop spread.
# Explicitly enable 3-finger vertical swipe so Mission Control is guaranteed
# reachable by gesture (up = Mission Control, down = App Expose) - with the
# 4-finger variant disabled, this must not depend on the machine's prior
# GUI state. 3-finger horizontal keeps its macOS default (switches Spaces).
# Value 0 disables, 2 enables.
# Both domains exist; built-in trackpad reads the first, Bluetooth the second.
for domain in com.apple.AppleMultitouchTrackpad com.apple.driver.AppleBluetoothMultitouch.trackpad; do
    defaults write "$domain" TrackpadThreeFingerVertSwipeGesture  -int 2
    defaults write "$domain" TrackpadFourFingerHorizSwipeGesture  -int 0
    defaults write "$domain" TrackpadFourFingerVertSwipeGesture   -int 0
    defaults write "$domain" TrackpadFourFingerPinchGesture        -int 0
    defaults write "$domain" TrackpadFiveFingerPinchGesture        -int 0
done

# Menu bar: always autohide.
defaults write NSGlobalDomain _HIHideMenuBar -bool true

# Windows: hold Ctrl+Cmd and drag anywhere inside a window to move it, not
# just the title bar (Linux-style Super+drag). Hidden AppKit preference with
# no System Settings UI; move-only, and the modifier combo is fixed. Applies
# to apps launched after the write, so already-running apps need a relaunch.
# Non-AppKit windows can ignore it (some Electron apps; Ghostty with
# window-decoration = false).
defaults write NSGlobalDomain NSWindowShouldDragOnGesture -bool true

# Dock: autohide and a small but legible tile size.
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock tilesize -int 59

# Finder: add a Quit menu item so Cmd+Q closes it like any other app.
defaults write com.apple.finder QuitMenuItem -bool true

# Cyclist: every setting is a user default (the Cyclist README documents
# the full key table); writes apply to a running Cyclist immediately.
# Only non-default values belong here.
defaults write io.github.pszypowicz.Cyclist aerospaceIntegration -bool true

# Text input: disable macOS auto-substitutions (capitalization, smart quotes/dashes,
# auto-period, spelling correction, smart-reply suggestions).
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled     -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled   -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled  -bool false
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
defaults write NSGlobalDomain NSSmartReplyEnabled                  -bool false

# Keyboard: remap Caps Lock to Escape for every keyboard. macOS stores the
# "All Keyboards" entry from System Settings > Keyboard > Keyboard Shortcuts >
# Modifier Keys under the wildcard device key 0-0-0 (vendor 0, product 0,
# keyboard type 0) in the per-host global domain - so this is hardware-
# independent and applies to built-in and external keyboards alike. HID usage
# codes: 0x700000039 (Caps Lock) = 30064771129, 0x700000029 (Escape) =
# 30064771113. Written as an XML plist value so the codes land as integers,
# matching what the GUI panel produces. Takes effect after logout.
defaults -currentHost write -g com.apple.keyboard.modifiermapping.0-0-0 \
    '<array><dict><key>HIDKeyboardModifierMappingSrc</key><integer>30064771129</integer><key>HIDKeyboardModifierMappingDst</key><integer>30064771113</integer></dict></array>'

# Mission Control space-switch hotkeys (79-82) stay on their macOS defaults:
# Cyclist's event tap consumes Ctrl+Left/Right before the system hotkey layer
# sees it, so the native Ctrl+Arrow binding costs nothing while Cyclist runs
# and serves as the fallback (macOS's animated slide) when it does not.
#
# Mission Control overview (ID 32) stays on its Ctrl+Up default. Cyclist only
# swallows Ctrl+Left/Right, so Ctrl+Up passes through to the native action -
# but GUI shortcut toggling can leave 32 disabled in the plist, so enable it
# explicitly. value parameters = (key char, key code, modifier mask):
# 65535 = non-printable, 126 = Up; mask 8650752 = Control(262144) + the
# function-key bit(8388608) macOS sets on arrow keys. Takes effect after
# logout; cfprefsd is killed below to ensure the write is flushed to disk.
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 32 \
    "{enabled = 1; value = {parameters = (65535, 126, 8650752); type = standard;};}"

# Apply Dock and Finder changes immediately; flush cfprefsd so the
# symbolichotkeys write lands on disk; the rest take effect on next login.
killall cfprefsd 2>/dev/null || true
killall Dock 2>/dev/null || true
killall Finder 2>/dev/null || true
