#!/usr/bin/env bash
set -euo pipefail

# macos/defaults - apply macOS preference defaults.
# Idempotent and safe to re-run. Invoked from ../bootstrap, but can also
# be run standalone to re-apply just this block without redoing the rest
# of the bootstrap.

usage() {
    cat <<'EOF'
Usage: macos/defaults [--help]

Apply macOS preference defaults. Idempotent and safe to re-run.

Touches:
  - Hammerspoon config path
  - Trackpad: disable 3- and 4-finger horizontal swipe between full-screen apps,
    disable 4-finger vertical swipe (frees both up/down for Hammerspoon - the
    4-finger up handler routes to tmux's session tree; 3-finger swipe up still
    triggers macOS Mission Control), and disable Launchpad pinch / Show Desktop spread
  - Menu bar: always autohide
  - Dock: autohide, tile size 59
  - Text input: disable auto-capitalization, smart quotes/dashes,
    auto-period, spelling correction, smart-reply suggestions
  - Mission Control: disable Ctrl+Arrow / Ctrl+Shift+Arrow space-switching
    hotkeys so Hammerspoon owns those chords (takes effect after logout).

Options:
  -h, --help    Show this help and exit.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        *) echo "unknown argument: $1" >&2; usage >&2; exit 2 ;;
    esac
done

defaults write org.hammerspoon.Hammerspoon MJConfigFile "$HOME/.config/hammerspoon/init.lua"

# Trackpad: disable horizontal swipe between full-screen apps (3- and 4-finger),
# and disable 4-finger vertical swipe so Hammerspoon owns 4-finger up (it routes
# to tmux's session tree) and 4-finger down stays inert. Three-finger swipe up
# still triggers macOS Mission Control. Value 0 disables, 2 enables.
# Both domains exist; built-in trackpad reads the first, Bluetooth the second.
for domain in com.apple.AppleMultitouchTrackpad com.apple.driver.AppleBluetoothMultitouch.trackpad; do
    defaults write "$domain" TrackpadThreeFingerHorizSwipeGesture -int 0
    defaults write "$domain" TrackpadFourFingerHorizSwipeGesture  -int 0
    defaults write "$domain" TrackpadFourFingerVertSwipeGesture   -int 0
    defaults write "$domain" TrackpadFourFingerPinchGesture        -int 0
    defaults write "$domain" TrackpadFiveFingerPinchGesture        -int 0
done

# Menu bar: always autohide.
defaults write NSGlobalDomain _HIHideMenuBar -bool true

# Dock: autohide and a small but legible tile size.
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock tilesize -int 59

# Text input: disable macOS auto-substitutions (capitalization, smart quotes/dashes,
# auto-period, spelling correction, smart-reply suggestions).
defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled     -bool false
defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled   -bool false
defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled  -bool false
defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false
defaults write NSGlobalDomain NSSmartReplyEnabled                  -bool false

# Mission Control: disable the four space-switching hotkeys so the chords are
# free for Hammerspoon to claim. IDs:
#   79 = Move left a space          (Ctrl+Left)
#   80 = Move left a space + apps   (Ctrl+Shift+Left)
#   81 = Move right a space         (Ctrl+Right)
#   82 = Move right a space + apps  (Ctrl+Shift+Right)
# These take effect after logout; cfprefsd is killed below to ensure the
# write is flushed to disk before that.
for id in 79 80 81 82; do
    defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys \
        -dict-add "$id" "{enabled = 0;}"
done

# Apply Dock changes immediately; flush cfprefsd so the symbolichotkeys
# write lands on disk; the rest take effect on next login.
killall cfprefsd 2>/dev/null || true
killall Dock 2>/dev/null || true
