{
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "CLAUDE_CODE_USE_VERTEX": "0",
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_INSTALLATION_CHECKS": "1",
    "CLAUDE_ENABLE_STREAM_WATCHDOG": "1",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\a'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -x ~/.config/journal-agent/hooks/claude-stop-hook.sh && ~/.config/journal-agent/hooks/claude-stop-hook.sh || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(jq -r '.tool_input.file_path') && if [[ \"$file_path\" == *.md && \"$file_path\" != */.claude/plans/* ]]; then prettier --write \"$file_path\"; fi"
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; echo \"$f\" | grep -q '\\.tf$' && terraform fmt \"$f\" || true; }",
            "statusMessage": "Running terraform fmt..."
          },
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read -r f; if [[ \"$f\" == *.tf ]]; then d=$(dirname \"$f\"); while [[ \"$d\" != \"/\" ]]; do if [[ -f \"$d/.terraform-docs.yml\" ]]; then cd \"$d\" && terraform-docs .; break; fi; d=$(dirname \"$d\"); done; fi; } 2>/dev/null || true",
            "statusMessage": "Running terraform-docs..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh",
    "refreshInterval": 60
  },
  "enabledPlugins": {
    "microsoft-docs@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "swift-concurrency@claude-skills": true,
    "ado@claude-skills": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-skills": {
      "source": {
        "source": "directory",
        "path": "/Users/pszypowicz/Developer/github.com/pszypowicz/claude-skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "theme": "auto"
}
