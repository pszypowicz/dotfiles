# Appearance
theme = light:GitHub Light Default,dark:Catppuccin Mocha
font-family = CaskaydiaCove Nerd Font
font-size = 14
macos-option-as-alt = left
window-padding-x = 8
window-padding-y = 8

# No confirmation prompt when closing a window/surface with a running process
confirm-close-surface = false

# This is a self-built fork (the ghostty-gestures cask) that shares the
# com.mitchellh.ghostty bundle id. Disable Sparkle auto-update so an official
# release can't silently replace the fork build.
auto-update = off

# Tabs are unused (tmux handles multiplexing): hide the tab bar and unbind
# every tab-related shortcut so one can't be opened by accident.
window-show-tab-bar = never
keybind = super+t=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
keybind = super+alt+w=unbind

# Command palette off
keybind = super+shift+p=unbind

# Switch tmux windows like Safari tabs (Cmd+Shift+[ and Cmd+Shift+])
keybind = super+shift+left_bracket=text:\x02p
keybind = super+shift+right_bracket=text:\x02n

# Paste tmux buffer (Cmd+Shift+V -> tmux prefix + ] -> paste-buffer)
keybind = super+shift+v=text:\x02]

# Jump directly to tmux windows 1-9 (Cmd+1..9)
keybind = super+digit_1=text:\x021
keybind = super+digit_2=text:\x022
keybind = super+digit_3=text:\x023
keybind = super+digit_4=text:\x024
keybind = super+digit_5=text:\x025
keybind = super+digit_6=text:\x026
keybind = super+digit_7=text:\x027
keybind = super+digit_8=text:\x028
keybind = super+digit_9=text:\x029

# Two-finger double-tap (trackpad "smart zoom") -> tmux session list (prefix + s).
gesture = smart-magnify = text:\x02s

# Disable pinch-to-zoom (font size); pinch is unused - only the double-tap above.
gesture = pinch-in =
gesture = pinch-out =

# Two-finger horizontal swipes drive tmux window switching (prefix + p/n).
# `force:` fires inside tmux's mouse reporting, and the gesture claim
# swallows the swipe's scroll copy including its momentum tail, so tmux
# receives exactly one command per physical swipe - no wheel recognition,
# no inertia. Swipe left = next window, the content metaphor. Like the
# super+digit keybinds above, the prefix sequence is sent regardless of
# what runs in the surface - this setup assumes tmux everywhere.
gesture = swipe-left:2 = force:text:\x02n
gesture = swipe-right:2 = force:text:\x02p

# Cmd + two-finger swipe stays with Ghostty's own tabs. Explicit bindings
# are required: modified triggers fire only when bound - there is no
# fallback to the unmodified binding.
gesture = cmd+swipe-left:2 = next_tab
gesture = cmd+swipe-right:2 = previous_tab

# Bell features: keep `attention` (Dock bounce on bell while unfocused) but
# disable `title` so the macOS window title isn't decorated with "🔔 " on a
# pending bell - the title stays a clean "session / window" readout, and the
# notification from Claude Code's page hook is the actual signal.
bell-features = no-system,no-audio,attention,no-title,no-border
