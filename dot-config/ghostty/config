# Appearance
theme = light:GitHub Light Default,dark:Catppuccin Mocha
font-family = CaskaydiaCove Nerd Font
font-size = 14
macos-option-as-alt = left
window-padding-x = 8
window-padding-y = 8

# No confirmation prompt when closing a window/surface with a running process
confirm-close-surface = false

# This is a self-built fork (the ghostty-personal cask) that shares the
# com.mitchellh.ghostty bundle id. The Sparkle updater is compiled out of
# this build; auto-update stays off as a guard for any stock build that
# ever reads this config.
auto-update = off

# Command palette off
keybind = super+shift+p=unbind

# Switch tmux windows like Safari tabs (Cmd+Shift+[ and Cmd+Shift+]);
# no-ops when no tmux client is attached to this surface. The translated
# [ / ] variants carry the previous/next_tab defaults and are unbound so
# only the physical-key tmux bindings remain.
keybind = super+shift+left_bracket=tmux_command:previous-window
keybind = super+shift+right_bracket=tmux_command:next-window
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind

# Paste tmux buffer (Cmd+Shift+V -> tmux prefix + ] -> paste-buffer)
keybind = super+shift+v=text:\x02]

# Two-finger double-tap (trackpad "smart zoom") -> tmux session list.
# tmux_command resolves the session attached to this surface over the
# server socket, so nothing is sent when tmux isn't running.
gesture = smart-magnify = tmux_command:choose-tree -Zs

# Disable pinch-to-zoom (font size); pinch is unused - only the double-tap above.
gesture = pinch-in =
gesture = pinch-out =

# Two-finger horizontal swipes drive tmux window switching. `force:` fires
# inside tmux's mouse reporting, and the gesture claim swallows the swipe's
# scroll copy including its momentum tail, so tmux receives exactly one
# command per physical swipe - no wheel recognition, no inertia. Swipe
# left = next window, the content metaphor. tmux_command targets the tmux
# client attached to this surface's tty over the server socket - without
# tmux the gesture is a no-op and the shell never sees stray prefix keys.
gesture = swipe-left:2 = force:tmux_command:next-window
gesture = swipe-right:2 = force:tmux_command:previous-window

# Bell features: keep `attention` (Dock bounce on bell while unfocused) but
# disable `title` so the macOS window title isn't decorated with "🔔 " on a
# pending bell - the title stays a clean "session / window" readout, and the
# notification from Claude Code's page hook is the actual signal.
bell-features = no-system,no-audio,attention,no-title,no-border
