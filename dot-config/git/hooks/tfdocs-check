#!/usr/bin/env zsh
set -e

# Dirs with staged .tf files
dirs=(${(f)"$(git diff --cached --name-only --diff-filter=ACMR -- '*.tf' | xargs -n1 dirname | sort -u)"})
(( ${#dirs} )) || exit 0

# Make the working tree match the index, so --output-check compares against
# the staged README rather than a locally-modified one.
if ! git diff --quiet; then
  git stash push -q --keep-index -m pre-commit-tfdocs
  trap 'git stash pop -q' EXIT
fi

for dir in $dirs; do
  [[ -f "$dir/.terraform-docs.yml" ]] || continue
  (cd $dir && terraform-docs . --output-check >/dev/null) || {
    echo "terraform-docs stale or unstaged in $dir" >&2
    exit 1
  }
done
