[credential]
	helper = osxkeychain
[push]
	default = current
[pager]
	branch = false
[core]
	autocrlf = false
	eol = lf
	excludesfile = ~/.config/git/ignore
	fileMode = false
	hooksPath = ~/.config/git/hooks

[pull]
	ff = only
[init]
	defaultBranch = main
[sequence]
	editor = code --wait

[user]
	name = Przemysław Szypowicz

[includeIf "gitdir:~/Developer/github.com/"]
	path = ~/.config/git/github.config
[include]
	path = ~/.config/git/config.local
