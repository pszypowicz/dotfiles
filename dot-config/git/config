[credential]
	helper = osxkeychain
[push]
	default = current
[pager]
	branch = false
[core]
	autocrlf = false
	eol = lf
	excludesfile = ~/.config/git/ignore
	fileMode = false

[pull]
	ff = only
[init]
	defaultBranch = main

[user]
	name = Przemysław Szypowicz

[includeIf "gitdir:~/Developer/github.com/"]
	path = ~/.config/git/github.config
[include]
	path = ~/.config/git/config.local
